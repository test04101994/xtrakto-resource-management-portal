# AWS Region
AWS_REGION=us-east-1

# DynamoDB Table Names (set automatically by CloudFormation in Lambda)
EMPLOYEES_TABLE=allocation-dashboard-employees
COST_CODES_TABLE=allocation-dashboard-cost-codes
ALLOCATIONS_TABLE=allocation-dashboard-allocations
CREDENTIALS_TABLE=allocation-dashboard-credentials

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
